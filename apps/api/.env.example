# Host-side API + Prisma configuration (copy to apps/api/.env).
# Used when running `prisma migrate` / the API directly on the host. The container
# receives the same variables from infra/.env via docker compose.

# Points at the compose Postgres published on localhost.
DATABASE_URL=postgresql://atomquest:atomquest_dev_pw@localhost:5432/atomquest?schema=public

NODE_ENV=development
API_PORT=8080

# LiveKit signaling URL and API credentials (dev values; rotate for deploy).
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret0001

# Allowed browser origin for CORS (the Vite dev server).
WEB_ORIGIN=http://localhost:5173

# Signs agent session cookies and customer invite tokens (>= 16 chars).
AUTH_JWT_SECRET=replace_with_a_long_random_secret
# Optional one-click demo agents (JSON). Defaults to a single "Demo Agent".
# SEED_AGENTS=[{"email":"demo.agent@thefoyers.club","name":"Demo Agent"}]
