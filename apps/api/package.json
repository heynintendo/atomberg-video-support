    "@prisma/client": "^5.22.0",
    "fastify": "^5.1.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
