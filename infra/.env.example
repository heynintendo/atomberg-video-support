# Compose environment (copy to infra/.env). docker compose auto-loads infra/.env.
# No real secret is committed; fill these with local values.

# --- Postgres ---
POSTGRES_USER=atomquest
POSTGRES_PASSWORD=replace_with_local_password
POSTGRES_DB=atomquest

# Database URL used INSIDE the compose network (host = service name "postgres").
DATABASE_URL=postgresql://atomquest:replace_with_local_password@postgres:5432/atomquest?schema=public

# --- LiveKit ---
# Injected into the SFU via LIVEKIT_KEYS and used by the API to mint tokens.
# The secret must be at least 32 characters.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace_with_a_secret_at_least_32_chars__
LIVEKIT_URL=ws://livekit:7880
# Browser-facing signaling URL returned to clients (published address, not the
# internal service name). For the deploy phase this becomes wss://<livekit-domain>.
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# --- API ---
NODE_ENV=development
API_PORT=8080
WEB_ORIGIN=http://localhost:5173

# --- Deploy only (Phase 2, single hostname behind Caddy) ---
# ACME CA: Let's Encrypt staging while iterating, production once stable.
ACME_CA=https://acme-v02.api.letsencrypt.org/directory
ACME_EMAIL=you@example.com
# Long-term TURN credential for coturn (also advertised to clients via LiveKit
# rtc.turn_servers). Generate a random value; it is injected, not committed.
TURN_PASSWORD=replace_with_a_random_value
# In production LIVEKIT_PUBLIC_URL is wss://<your-domain> (TLS via Caddy).
